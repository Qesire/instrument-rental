/* 个人中心页样式 */
.user-section {
  margin-bottom: 24rpx;
}

.user-header {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: #f0f0f0;
  margin-right: 24rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-nickname {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.login-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.login-text {
  color: #999999;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.login-btn {
  width: 400rpx;
}

.menu-section {
  margin-bottom: 24rpx;
}

.menu-card {
  padding: 0;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  color: #333333;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-arrow {
  color: #cccccc;
  font-size: 36rpx;
}

.logout-section {
  padding-top: 40rpx;
}

.logout-btn {
  width: 100%;
  background-color: #ffffff;
  color: #e74c3c;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 30rpx;
  border: 1rpx solid #e0e0e0;
}