<!-- 个人中心 -->
<view class="container">
  <!-- 用户信息区域 -->
  <view class="user-section card">
    <view wx:if="{{isLoggedIn}}">
      <view class="user-header">
        <image
          class="user-avatar"
          src="{{userInfo.avatarUrl || ''}}"
          mode="aspectFill"
        />
        <view class="user-info">
          <text class="user-nickname">{{userInfo.nickname || '用户'}}</text>
          <text class="text-muted">{{userInfo.phone || '未绑定手机号'}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="login-area">
      <text class="login-text">登录后可查看预约信息</text>
      <button class="btn-primary login-btn" bindtap="onWechatLogin">
        微信一键登录
      </button>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="card menu-card">
      <view class="menu-item" data-type="myReservations" bindtap="onMenuItemTap">
        <text>我的预约</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" data-type="favorites" bindtap="onMenuItemTap">
        <text>我的收藏</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" data-type="help" bindtap="onMenuItemTap">
        <text>帮助中心</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" data-type="about" bindtap="onMenuItemTap">
        <text>关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>
</view>