/* 乐器列表页样式 */
.search-row {
  margin-bottom: 20rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 8rpx 24rpx;
}

.search-input {
  flex: 1;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.search-clear {
  padding: 8rpx 12rpx;
  color: #999999;
  font-size: 24rpx;
}

.category-filter {
  white-space: nowrap;
  margin-bottom: 20rpx;
  padding: 10rpx 0;
}

.filter-tag {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background-color: #ffffff;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666666;
}

.filter-tag.active {
  background-color: #d4a574;
  color: #ffffff;
}

.model-list {
  display: flex;
  flex-direction: column;
}

.model-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.model-image {
  width: 200rpx;
  height: 200rpx;
  background-color: #f5f5f5;
}

.model-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.model-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.model-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.model-stock {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.stock-count {
  font-size: 28rpx;
  font-weight: bold;
  color: #d4a574;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}