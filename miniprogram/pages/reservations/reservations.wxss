/* 我的预约页样式 */
.login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 16rpx;
}

.login-hint {
  font-size: 24rpx;
}

.reservation-card {
  margin-bottom: 20rpx;
}

.res-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.res-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.res-brand {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
}

.res-body {
  margin-bottom: 16rpx;
}

.res-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.pickup-code {
  font-size: 36rpx;
  font-weight: bold;
  color: #d4a574;
  letter-spacing: 4rpx;
}

.res-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #999999;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
  line-height: 1.4;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}